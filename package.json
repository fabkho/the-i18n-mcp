{
  "name": "the-i18n-mcp",
  "version": "2.3.0",
  "mcpName": "io.github.fabkho/the-i18n-mcp",
  "description": "MCP server for managing i18n translation files — supports Nuxt and Laravel out of the box",
  "author": "Fabian Kirchhoff",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fabkho/the-i18n-mcp.git"
  },
  "homepage": "https://github.com/fabkho/the-i18n-mcp#readme",
  "bugs": {
    "url": "https://github.com/fabkho/the-i18n-mcp/issues"
  },
  "keywords": [
    "mcp",
    "i18n",
    "nuxt",
    "vue",
    "laravel",
    "php",
    "translations",
    "model-context-protocol",
    "ai",
    "locale",
    "internationalization"
  ],
  "bin": {
    "the-i18n-mcp": "./dist/index.js",
    "nuxt-i18n-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "schema.json"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:perf": "vitest run tests/perf/",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.23.0",
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "dependency-graph": "^1.0.0",
    "php-array-reader": "^2.1.3",
    "tinyglobby": "^0.2.15",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@nuxt/kit": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@nuxt/kit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nuxt/kit": "^4.4.2",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "tsdown": "^0.12.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.2.0"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=18.12.0"
  }
}
