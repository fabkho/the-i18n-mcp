{
  "name": "the-i18n-cli",
  "version": "1.0.1",
  "description": "CLI and core library for managing i18n translation files",
  "author": "Fabian Kirchhoff",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fabkho/the-i18n-kit.git",
    "directory": "packages/cli"
  },
  "bin": {
    "the-i18n-cli": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "dependency-graph": "^1.0.0",
    "php-array-reader": "^2.1.3",
    "tinyglobby": "^0.2.15",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@nuxt/kit": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@nuxt/kit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nuxt/kit": "^4.4.2",
    "@types/node": "^22.0.0",
    "tsdown": "^0.12.0",
    "vitest": "^3.2.0"
  }
}
